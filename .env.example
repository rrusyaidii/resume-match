# Required: AI provider
OPENROUTER_API_KEY=sk-or-your-key-here

# Access gate: unlimited analyses when password is entered
# Use a long random string (20+ chars) — not a personal name or guessable word
ACCESS_PASSWORD=your-access-password

# Sign access cookies — generate with: openssl rand -base64 32
COOKIE_SECRET=your-random-secret-at-least-32-chars

# Optional: public site URL for OpenGraph
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
