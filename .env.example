# Required: AI provider
OPENROUTER_API_KEY=sk-or-your-key-here

# Access gate: unlimited analyses when password is entered
# Use a long random string (20+ chars) — not a personal name or guessable word
ACCESS_PASSWORD=your-access-password

# Sign access cookies — generate with: openssl rand -base64 32
COOKIE_SECRET=your-random-secret-at-least-32-chars

# Server-side free-tier usage tracking (Upstash Redis — console.upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: Cloudflare Turnstile for free-tier analyze (https://dash.cloudflare.com/turnstile)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional: public site URL for OpenGraph
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Google Sheets export (OAuth — console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override; defaults to NEXT_PUBLIC_SITE_URL/api/google/callback
GOOGLE_REDIRECT_URI=
